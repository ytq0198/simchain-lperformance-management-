# 监听端口
PORT=3000

# JWT（登录演示；生产务必更换）
JWT_SECRET=please-change-in-production
# JWT_EXPIRES_IN=12h

# Fabric（与 test-network 默认一致）
CHANNEL_NAME=mychannel
CHAINCODE_NAME=score
MSP_ID=Org1MSP
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.org1.example.com

# Org2（学生 student01、用人单位 hr001 使用；默认由 FABRIC_CRYPTO_BASE 推导为 org2.example.com）
# FABRIC_CRYPTO_BASE_ORG2=
MSP_ID_ORG2=Org2MSP
PEER_ENDPOINT_ORG2=localhost:9051
PEER_HOST_ALIAS_ORG2=peer0.org2.example.com

# 必须为「绝对路径」：指向 org1.example.com 的 peerOrganizations 根目录
# 须先在 test-network 目录执行过 ./network.sh up，才会生成 organizations/…/users/…
# 例（按你虚拟机用户与拷贝位置修改）：
# FABRIC_CRYPTO_BASE=/home/tony/work/fabric-packages/fabric/fabric/scripts/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com

FABRIC_CRYPTO_BASE=/home/tony/work/fabric-packages/fabric/fabric/scripts/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com
